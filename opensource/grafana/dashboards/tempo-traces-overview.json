{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Trace Search",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "queryType": "traceql",
          "query": "{ resource.service.name =~ \"$service\" }",
          "limit": 20,
          "tableType": "traces",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Error Traces",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 10 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "queryType": "traceql",
          "query": "{ resource.service.name =~ \"$service\" && status = error }",
          "limit": 20,
          "tableType": "traces",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Slow Traces (> 500ms)",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 18 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "queryType": "traceql",
          "query": "{ resource.service.name =~ \"$service\" && duration > 500ms }",
          "limit": 20,
          "tableType": "traces",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Trace by ID",
      "description": "Enter a Trace ID in the variable above to view the full trace",
      "type": "traces",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 26 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "queryType": "traceql",
          "query": "$trace_id",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Trace → Logs Correlation",
      "description": "Shows logs correlated to the Trace ID entered above",
      "type": "logs",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 38 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service_name=~\".+\"} |= \"$trace_id\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Ascending",
        "dedupStrategy": "none"
      }
    }
  ],
  "refresh": "",
  "schemaVersion": 39,
  "tags": ["tempo", "traces", "myrca"],
  "templating": {
    "list": [
      {
        "allValue": ".+",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "loki", "uid": "loki" },
        "definition": "label_values(service_name)",
        "includeAll": true,
        "multi": true,
        "name": "service",
        "query": "label_values(service_name)",
        "refresh": 2,
        "type": "query"
      },
      {
        "name": "trace_id",
        "type": "textbox",
        "current": { "value": "" },
        "label": "Trace ID"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Tempo — Traces Overview",
  "uid": "myrca-tempo-traces",
  "version": 2
}
